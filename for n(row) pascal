Generate Pascal triangle for given N(row) value 
def generateRow(row): 
    #main logic 
    ans = 1  
    result=[ans] 
    for col in range(1,row):
        ans = ans*(row-col)
        ans = ans//(col)  
        result.append(ans) 
    return result 
finalResult=[] 
rows = int(input("enter the number of the rows: ")) 
for row in range(1,rows+1):
    finalResult.append(generateRow(row)) 
for lst in finalResult:
    print(*lst)
